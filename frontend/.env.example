# Base URL of the backend API.
#
# - Development: the Vite dev server proxies "/api" to the backend
#   (see vite.config.js), so you can leave this as "/api".
# - Production build (npm run build + npm run preview): there is no proxy,
#   so set this to the backend's full URL, e.g. https://api.yourdomain.com/api
VITE_API_URL=http://localhost:5001/api
