# MongoDB connection string (local or Atlas)
MONGODB_URI=mongodb://localhost:27017/leetcode-analytics

# Secret used to sign JWTs — set to a long random string
JWT_SECRET=change-this-to-a-secure-random-string

# Port the API server listens on
PORT=5001

# Allowed CORS origins (comma-separated frontend URLs, no spaces)
FRONTEND_URL=http://localhost:5173

# Auto-sync interval in hours
SYNC_INTERVAL_HOURS=6

# Snapshot disk retention (each sync used to insert a NEW full copy forever)
# Now: max 1 successful snapshot per UTC day, then prune older history
SNAPSHOT_RETENTION_DAYS=45
SNAPSHOT_MAX_PER_STUDENT=45

# Timezone used for "today" rankings / daily solve dates (India by default)
APP_TIMEZONE=Asia/Kolkata

# development | production
NODE_ENV=development

# When NODE_ENV=production, public registration is disabled unless this is true
ALLOW_OPEN_REGISTER=false

# Super admin account created automatically on first boot
SUPER_ADMIN_EMAIL=admin@platform.local
SUPER_ADMIN_PASSWORD=change-this-password
SUPER_ADMIN_NAME=Super Admin
